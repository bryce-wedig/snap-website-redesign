---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

const allCourses = await getCollection('courses');
const available = allCourses.filter(c => !c.data.comingSoon);
const comingSoon = allCourses.filter(c => c.data.comingSoon);
---

<PageLayout title="Courses">
  <h2>Courses</h2>
  <hr />

  <div class="course-list">
    {available.map(course => (
      <a href={`${import.meta.env.BASE_URL}courses/${course.id}/`} class="course-card card">
        <h3>{course.data.title}</h3>
        <span class="course-link">View course &rarr;</span>
      </a>
    ))}
  </div>

  {comingSoon.length > 0 && (
    <>
      <h2 style="margin-top: 3rem;">Coming Soon</h2>
      <hr />
      <div class="course-list">
        {comingSoon.map(course => (
          <div class="course-card card coming-soon">
            <h3>{course.data.title}</h3>
            <span class="badge badge-upcoming">Coming Soon</span>
          </div>
        ))}
      </div>
    </>
  )}
</PageLayout>

<style>
  .course-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
  }

  .course-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .course-card h3 {
    margin-bottom: 0;
    transition: color var(--transition-fast);
  }

  .course-card:hover h3 {
    color: var(--snap-orange);
  }

  .course-link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--snap-orange);
    white-space: nowrap;
  }

  .coming-soon {
    opacity: 0.7;
    cursor: default;
  }

  .coming-soon:hover {
    transform: none;
    box-shadow: none;
  }
</style>
