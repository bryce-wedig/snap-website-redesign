---
import PageLayout from '../layouts/PageLayout.astro';
import { readFileSync } from 'fs';
import { parse } from 'yaml';
import { join } from 'path';

const siteData = parse(readFileSync(join(process.cwd(), 'src/data/site.yaml'), 'utf-8'));
---

<PageLayout title="Get Involved">
  <section class="join-hero">
    <h1>Ready to Get Involved?</h1>
    <p class="join-intro">
      Whether you're part of an established science policy group or an individual advocate, you're welcome here.
    </p>
  </section>

  <div class="join-actions">
    <div class="join-card card">
      <div class="join-icon"><i class="fa-solid fa-clipboard-list"></i></div>
      <h3>Complete the Interest Form</h3>
      <p>Join our mailing list and stay updated through our newsletter!</p>
      <a href={siteData.interest_form_url} target="_blank" rel="noopener" class="btn btn-primary">
        Interest Form <i class="fa-solid fa-arrow-up-right-from-square"></i>
      </a>
    </div>

    <div class="join-card card">
      <div class="join-icon"><i class="fa-brands fa-slack"></i></div>
      <h3>Join Our Slack</h3>
      <p>Connect with fellow advocates, organize initiatives, and access shared resources!</p>
      <p style="font-size: var(--text-sm); color: var(--snap-gray-500);">
        Indicate your interest via the Interest Form to receive an invite.
      </p>
    </div>

    <div class="join-card card">
      <div class="join-icon"><i class="fa-solid fa-envelope"></i></div>
      <h3>Contact Us</h3>
      <p>Have questions? Reach out to us directly.</p>
      <a href={`mailto:${siteData.email}`} class="btn btn-outline">
        <i class="fa-solid fa-envelope"></i> Send Email
      </a>
    </div>
  </div>
</PageLayout>

<style>
  .join-hero {
    text-align: center;
    margin-bottom: 2rem;
  }

  .join-intro {
    font-size: var(--text-lg);
    color: var(--snap-gray-600);
    max-width: 600px;
    margin: 0 auto;
  }

  .join-actions {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .join-card {
    text-align: center;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .join-icon {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: var(--radius-full);
    background: var(--snap-gray-100);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    color: var(--snap-navy);
  }

  .join-card h3 {
    margin-bottom: 0;
  }

  .join-card p {
    margin-bottom: 0.5rem;
    font-size: var(--text-sm);
    color: var(--snap-gray-600);
    line-height: 1.6;
  }
</style>
