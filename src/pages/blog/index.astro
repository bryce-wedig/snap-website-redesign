---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

function formatDate(d: Date): string {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<PageLayout title="Blog">
  <h2>Blog</h2>
  <p>
    SNAP hosts our blog on Medium through our publication
    <a href="https://medium.com/science-policy-in-a-snap" target="_blank" rel="noopener">Science Policy in a SNAP</a>.
    Follow both the publication page and
    <a href="https://medium.com/@snapscipolorg" target="_blank" rel="noopener">SNAP's page</a>
    on Medium to get notified whenever we publish a new blog post!
  </p>
  <hr />

  <div class="blog-list">
    {posts.map(post => (
      <a href={`${import.meta.env.BASE_URL}blog/${post.id}/`} class="blog-card card">
        <span class="blog-date">{formatDate(post.data.date)}</span>
        <h3>{post.data.title}</h3>
        {post.data.author && <span class="blog-author">By {post.data.author}</span>}
        {post.data.excerpt && <p class="blog-excerpt">{post.data.excerpt}</p>}
      </a>
    ))}
  </div>
</PageLayout>

<style>
  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .blog-card {
    text-decoration: none;
    color: inherit;
  }

  .blog-card:hover h3 {
    color: var(--snap-orange);
  }

  .blog-date {
    font-size: var(--text-xs);
    color: var(--snap-gray-500);
    font-weight: 600;
  }

  .blog-card h3 {
    margin-bottom: 0.25rem;
    transition: color var(--transition-fast);
  }

  .blog-author {
    font-size: var(--text-sm);
    color: var(--snap-gray-500);
  }

  .blog-excerpt {
    font-size: var(--text-sm);
    color: var(--snap-gray-600);
    margin-top: 0.5rem;
    line-height: 1.6;
  }
</style>
