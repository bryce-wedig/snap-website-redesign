---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

const allInitiatives = await getCollection('initiatives');

const categories = [
  { key: 'current', title: 'Current Initiatives', badgeClass: 'badge-current' },
  { key: 'past', title: 'Past Initiatives', badgeClass: 'badge-past' },
  { key: 'upcoming', title: 'Upcoming Initiatives', badgeClass: 'badge-upcoming' },
];
---

<PageLayout title="Initiatives">
  {categories.map(cat => {
    const items = allInitiatives
      .filter(i => i.data.category === cat.key)
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

    return items.length > 0 && (
      <section style="margin-bottom: 3rem;">
        <h2>{cat.title}</h2>
        <hr />
        <div class="initiative-list">
          {items.map(item => (
            <a href={`${import.meta.env.BASE_URL}initiatives/${item.id}/`} class="initiative-card card">
              <div class="initiative-header">
                <h3>{item.data.title}</h3>
                <span class={`badge ${cat.badgeClass}`}>{cat.key}</span>
              </div>
              {item.data.excerpt && <p class="initiative-excerpt">{item.data.excerpt}</p>}
            </a>
          ))}
        </div>
      </section>
    );
  })}
</PageLayout>

<style>
  .initiative-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
  }

  .initiative-card {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .initiative-card:hover h3 {
    color: var(--snap-orange);
  }

  .initiative-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .initiative-header h3 {
    margin-bottom: 0;
    transition: color var(--transition-fast);
  }

  .initiative-excerpt {
    margin-top: 0.5rem;
    font-size: var(--text-sm);
    color: var(--snap-gray-600);
    line-height: 1.6;
  }
</style>
