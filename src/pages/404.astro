---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Page Not Found">
  <section style="text-align: center; padding: 4rem 0;">
    <h1 style="font-size: 5rem; margin-bottom: 0.5rem;">404</h1>
    <h2>Page Not Found</h2>
    <p style="color: var(--snap-gray-500); margin-bottom: 2rem;">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a href={import.meta.env.BASE_URL} class="btn btn-primary">Go Home</a>
  </section>
</PageLayout>
