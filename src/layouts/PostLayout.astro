---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  date?: Date;
  author?: string;
  description?: string;
}

const { title, date, author, description } = Astro.props;

function formatDate(d: Date | undefined): string {
  if (!d) return '';
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title={title} description={description}>
  <Header slot="header" />

  <article class="container" style="padding-top: 2rem; padding-bottom: 3rem; min-height: 60vh;">
    <header style="margin-bottom: 2rem;">
      <h1>{title}</h1>
      {(date || author) && (
        <div style="color: var(--snap-gray-500); font-size: var(--text-sm); display: flex; gap: 1rem; flex-wrap: wrap;">
          {date && <span><i class="fa-regular fa-calendar"></i> {formatDate(date)}</span>}
          {author && <span><i class="fa-regular fa-user"></i> {author}</span>}
        </div>
      )}
      <hr />
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>

  <Footer slot="footer" />
</BaseLayout>
